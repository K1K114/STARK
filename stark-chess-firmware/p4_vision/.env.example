# Copy to .env (same folder) — do not commit .env with real secrets.

WIFI_SSID=PAL3.0
WIFI_USERNAME=your_username
WIFI_PASSWORD=your_password

# Python STARK server (same machine as `uvicorn server.main:app` or LAN IP).
STARK_SERVER_HOST=192.168.1.100
STARK_SERVER_PORT=8000

# WS2812 strip (0-based indices in firmware must cover all mapped indices).
LED_DATA_PIN=39
NEOPIXEL_COUNT=48
